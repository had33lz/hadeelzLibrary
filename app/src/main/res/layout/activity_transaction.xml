<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Book Transaction"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/slate"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Borrow and return management"
            android:textSize="13sp"
            android:textColor="@color/olive"
            android:layout_marginBottom="32dp"/>

        <!-- Student Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Student Name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editStudentName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:textColor="@color/slate"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Book Title -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Book Title"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editBookTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/slate"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Borrow Date -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Borrow Date (YYYY-MM-DD)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="12dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editBorrowDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:textColor="@color/slate"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Return Date -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Return Date (YYYY-MM-DD)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_marginBottom="20dp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/editReturnDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:textColor="@color/slate"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/burlap"
            android:layout_marginBottom="20dp"/>

        <!-- Result Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/coconut"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Calculation Result"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/cinnamon"
                android:layout_marginBottom="12dp"/>

            <!-- Delay Days Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Delay Days:"
                    android:textColor="@color/slate"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtDelayDays"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 days"
                    android:textColor="@color/slate"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

            </LinearLayout>

            <!-- Fine Amount Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Fine Amount:"
                    android:textColor="@color/slate"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/txtFineAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.000 OMR"
                    android:textColor="@color/cinnamon"
                    android:textStyle="bold"
                    android:textSize="14sp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Calculate Button -->
        <Button
            android:id="@+id/btnCalculate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Calculate Fine"
            android:textColor="@color/white"
            android:backgroundTint="@color/olive"
            android:layout_marginBottom="12dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSaveTransaction"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Save Transaction"
            android:textColor="@color/white"
            android:backgroundTint="@color/cinnamon"
            android:layout_marginBottom="12dp"/>

        <!-- Reset Button -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Reset"
            android:textColor="@color/white"
            android:backgroundTint="@color/slate"
            android:layout_marginBottom="12dp"/>

        <!-- Back Button -->
        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Back to Dashboard"
            android:textColor="@color/slate"
            android:backgroundTint="@color/burlap"/>

    </LinearLayout>
</ScrollView>