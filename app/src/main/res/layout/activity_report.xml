<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Reports"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/slate"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All books and transactions"
        android:textSize="13sp"
        android:textColor="@color/olive"
        android:layout_marginBottom="20dp"/>

    <!-- Tab Buttons Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnShowBooks"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Books"
            android:textColor="@color/white"
            android:backgroundTint="@color/cinnamon"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnShowTransactions"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="Transactions"
            android:textColor="@color/white"
            android:backgroundTint="@color/olive"/>

    </LinearLayout>

    <!-- Section Label -->
    <TextView
        android:id="@+id/txtSectionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Showing: Books"
        android:textSize="13sp"
        android:textStyle="italic"
        android:textColor="@color/cinnamon"
        android:layout_marginBottom="8dp"/>

    <!-- List View -->
    <ListView
        android:id="@+id/listViewReport"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/burlap"
        android:dividerHeight="1dp"/>

    <!-- Back Button -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Back to Dashboard"
        android:textColor="@color/slate"
        android:backgroundTint="@color/burlap"
        android:layout_marginTop="12dp"/>

</LinearLayout>